# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# MCP config (contains API keys — do not commit)
.mcp.json

# Claude Code per-user workspace state (worktrees, sessions, local settings)
.claude/

# Local Claude Code skills (not shared via repo)
/skills/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
